{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Startup Manager",
  "version": "1.0.0",
  "identifier": "com.chmzho.startup-manager",
  "build": {
    "frontendDist": "."
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Startup Manager",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
